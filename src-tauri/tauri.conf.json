{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AiO",
  "version": "0.1.0",
  "identifier": "com.moyu.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AiO",
        "label": "main",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "visible": true,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: file: asset: http://asset.localhost *; media-src 'self' file: asset: http://asset.localhost blob: https://*; connect-src 'self' https://* http://asset.localhost ws://localhost:*",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$APP/**", "$RESOURCE/**", "$HOME/**", "$DOCUMENT/**", "$DOWNLOAD/**", "$DESKTOP/**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "shortDescription": "AiO",
    "longDescription": "AiO - 桌面应用",
    "category": "Utility",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
